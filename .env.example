## Copy this file to .env and adjust values for your environment.
## These defaults are convenient for strict local-only development.
## Do not reuse unchanged values on shared/public networks.

# Shared upload API key for compose services and e2e build args
API_SHARED_TOKEN=dev-token
VITE_UPLOAD_API_URL=http://localhost:8080

# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=admin

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# LocalStack / S3-compatible clients (local only)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# InfluxDB bootstrap + service config
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=adminadmin
INFLUXDB_TOKEN=acerbi-dev-influxdb-token
INFLUXDB_ORG=acerbi-dev
INFLUXDB_BUCKET=metrics

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
